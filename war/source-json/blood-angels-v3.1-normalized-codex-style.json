  "special_rules": [
    {
      "name": "Space Marine Special Rules",
      "text": "The Space Marine Transport and They Shall Know No Fear rules apply to Blood Angels armies."
    },
    {
      "name": "Lucifer Pattern Engines",
      "text": "Units marked as having Lucifer Pattern Engines may add +5cm to their movement when carrying out an engage action."
    },
    {
      "name": "Red Thirst",
      "text": "If any stand in the formation could reach base contact with an enemy unit, the formation receives a -1 penalty to activate using any order other than Engage. If an Engage order is chosen, the formation automatically passes the activation roll regardless of any other modifiers or penalties. There is no subsequent requirement to reach base contact if the player does not wish to."
    }
  ],
